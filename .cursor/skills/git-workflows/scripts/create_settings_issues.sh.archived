#!/usr/bin/env bash
# ARCHIVED: SvelteKit-specific feature issues - not applicable to Angular
# This script created GitHub issues for Universal-API SvelteKit settings features.
# Kept for reference but should not be executed for procurement-web.
set -euo pipefail

repo="MT-Hackathon/Universal-API"
api="https://api.github.com/repos/${repo}/issues"
token="${GITHUB_PERSONAL_ACCESS_TOKEN:?GITHUB_PERSONAL_ACCESS_TOKEN is required}"
labels='["frontend","feature"]'

post_issue() {
  local title="$1"
  local body="$2"
  echo "Creating: $title"
  jq -n --arg title "$title" --arg body "$body" --argjson labels "$labels" '{title:$title, body:$body, labels:$labels}' \
    | curl -sS -X POST \
      -H "Authorization: token $token" \
      -H "Accept: application/vnd.github+json" \
      "$api" -d @-
  echo
}

post_issue "Settings API: write to default_app_settings.json and en.json" "$(cat <<'EOB'
## Problem
Settings UI edits must persist to source files for developer-only low-code flow. Need backend API to write updates to `src/frontend/src/lib/config/default_app_settings.json` and `src/frontend/messages/en.json` safely.

## Requirements
- POST endpoint to accept validated payload for visual settings and copy
- Writes only to allowed files/paths; reject arbitrary paths
- Preserve JSON formatting (stable ordering) and validate JSON
- Authn/authz: restricted to dev/admin users
- Unit tests for validation and file write

## References
- default_app_settings.json
- messages/en.json
- settingsStore.ts

## Acceptance
- Endpoint writes changes safely with validation
- Errors on invalid schema or missing auth
- JSON remains valid and ordered
EOB
)"

post_issue "Settings API: rebuild trigger (Apply Changes support)" "$(cat <<'EOB'
## Problem
After writing settings/copy to source files, developers need to trigger a rebuild manually from the Settings page.

## Requirements
- Backend endpoint to trigger rebuild command
- Command configurable; default: `npm run build` or project-standard
- Run in repo root `/home/cmb115/projects/Universal-API`
- Stream/return status; handle failures gracefully
- Authn/authz restricted to dev/admin

## Acceptance
- Endpoint kicks off rebuild and returns status
- Fails safely with clear error if command fails
- Works on dev machines; production guarded/disabled by config
EOB
)"

post_issue "Remove CopySettings duplication; migrate copy to en.json" "$(cat <<'EOB'
## Problem
Copy is split between CopySettings (runtime) and Paraglide `en.json` (build-time). With Option E, settings UI will write directly to `en.json`. Need to consolidate to single source of truth.

## Tasks
- Audit where copy uses CopySettings vs `t()`
- Move customizable text to `messages/en.json`
- Remove redundant CopySettings fields and update types
- Ensure settings UI reads/writes `en.json` via new API
- Keep visual settings in `default_app_settings.json`

## Acceptance
- No duplicate copy sources; all strings resolved from `t()` backed by `en.json`
- Settings UI surfaces the relevant `en.json` entries for editing
- Types cleaned up accordingly
EOB
)"

post_issue "Settings UI: Add Apply Changes button (write + rebuild)" "$(cat <<'EOB'
## Problem
After editing settings/copy, developers need an explicit "Apply Changes" to persist to files and trigger rebuild.

## Requirements
- Button in settings header or footer
- On click: call settings write API, then rebuild trigger API
- Show progress/success/error states; disable during run
- Guard against unsaved changes; confirm before discard

## Acceptance
- Apply button successfully writes files and triggers rebuild
- Clear feedback on success/failure
- Prevents concurrent double-submit
EOB
)"

post_issue "Settings Navigation: reorganize sections for growth" "$(cat <<'EOB'
## Problem
Current navigation (General/Canvas/Toolbar/Nodes) is cramped. Need structure that matches full surface area.

## Proposed Structure
- Application: Branding, Behavior
- Appearance: Typography, Spacing & Radius, Elevation/Shadows, Buttons, Badges
- Canvas: Background, Grid, Empty State
- Layout: Header, Toolbar, Sidebar
- Nodes: Source, Transform, Destination (+ form overrides)
- Forms: Layout/Validation/Actions
- Hotkeys: Canvas, Forms, Global
- Copy & Text: Main page, Dialogs, Toasts, Connection tests, Empty state

## Acceptance
- Navigation updated to new structure
- Existing sections still reachable
- Placeholder/links for new sections
EOB
)"

